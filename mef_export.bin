    background-color: #ffffff;
}

.History
{
    width: 100%;
    margin: 0 auto;
    border-collapse: collapse;
    background-color: #ffffff;
    border: solid 1px #dddddd;
}

.History tr
{
    height: 20px;
}

.History tr.alt
{
}

.History td
{
    border-left: solid 1px #dddddd;
    border-right: solid 1px #dddddd;
}
/* Panel Historial - Fin */

/* Panel Datos */
#PnlData
{
    background-color: #ffffff;
}

.MapTable
