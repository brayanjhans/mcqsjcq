    color: #ffffff;
    border-collapse: collapse;
    border-width: 0px;
}

.MapTable tr
{
    height: 18px;
}

.MapTable td
{
    border: solid 1px #dddddd;
    text-align: center;
    font-weight: bold;
    vertical-align: middle;
}

.Data
